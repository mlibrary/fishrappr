<script>
  $(function() {
    $('#about a').on('click', function(e) {
      e.preventDefault();
      if ($('#about-content').html() == "") {
        $('#about-content').load($(this).attr("href"), function() {
          $('#about-content').show();
        });
      } else {
        $('#about-content').toggle();
      }
    });
  });
</script>
